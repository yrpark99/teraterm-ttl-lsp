{
  "comments": {
    "lineComment": { "comment": ";" },
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "/*", "close": "*/", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["'", "'"],
    ["\"", "\""]
  ],
  "wordPattern": "[A-Za-z_][A-Za-z0-9_]*",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(if\\b.*\\bthen\\b|else\\b|elseif\\b|while\\b|for\\b|do\\b|until\\b)(?!.*\\b(endif|endwhile|next|loop|enduntil)\\b).*$",
    "decreaseIndentPattern": "^\\s*(endif|else|elseif|endwhile|next|loop|enduntil)\\b.*$"
  }
}
