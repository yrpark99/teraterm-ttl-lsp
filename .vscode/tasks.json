{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$tsc"],
      "label": "npm: compile"
    },
    {
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^\\[\\w+\\] (.+)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[\\w+\\] building\\.\\.\\.$",
          "endsPattern": "^\\[watch\\] watching for changes\\.\\.\\.$|^\\[\\w+\\] done"
        }
      },
      "label": "npm: watch"
    }
  ]
}
